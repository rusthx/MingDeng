{
  "productName": "MingDeng",
  "version": "0.1.0",
  "identifier": "com.mingdeng",
  "build": {
    "beforeDevCommand": "cd src && python -m http.server 1420 --bind 127.0.0.1",
    "beforeBuildCommand":"",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: https:;"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "MingDeng - 明灯学习助手",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon_128.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend": "backend",
      "../backend-venv": "backend-venv"
    }
  }
}
