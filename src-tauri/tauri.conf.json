{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MingDeng",
  "version": "0.2.1",
  "identifier": "com.mingdeng.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MingDeng - 明灯学习助手",
        "width": 380,
        "height": 172,
        "minWidth": 360,
        "minHeight": 132,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
