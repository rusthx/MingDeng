{
  "name": "mingdeng",
  "version": "0.2.1",
  "private": true,
  "description": "MingDeng - lightweight AI learning assistant",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "version": "node scripts/sync-version.mjs && git add src-tauri/Cargo.toml src-tauri/tauri.conf.json",
    "release": "npm version patch -m 'chore: bump version to v%s' && git push --follow-tags"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "keywords": [
    "learning",
    "ai",
    "assistant",
    "tauri"
  ],
  "license": "MIT"
}
